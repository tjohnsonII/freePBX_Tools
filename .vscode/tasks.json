{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "helper: kill web ports",
      "type": "process",
      "command": "cmd.exe",
      "args": [
        "/d",
        "/c",
        "call",
        "${workspaceFolder}\\scripts\\kill_ports.bat",
        "8787",
        "3004"
      ],
      "problemMatcher": []
    },
    {
      "label": "bootstrap: dev envs",
      "type": "process",
      "command": "python",
      "args": [
        "${workspaceFolder}\\scripts\\bootstrap_venvs.py",
        "--all"
      ],
      "problemMatcher": []
    },
    {
      "label": "doctor: dev envs",
      "type": "process",
      "command": "python",
      "args": [
        "${workspaceFolder}\\scripts\\doctor_devs.py"
      ],
      "problemMatcher": []
    },
    {
      "label": "dev: web manager backend",
      "type": "process",
      "command": "cmd.exe",
      "args": [
        "/d",
        "/c",
        "call",
        "${workspaceFolder}\\scripts\\run_py.bat",
        ".venv-web-manager",
        "-m",
        "uvicorn",
        "webscraper_manager.api.server:app",
        "--reload",
        "--host",
        "127.0.0.1",
        "--port",
        "8787"
      ],
      "isBackground": true,
      "problemMatcher": [
        {
          "owner": "custom",
          "fileLocation": "absolute",
          "pattern": {
            "regexp": "^(.*)$",
            "file": 1,
            "message": 1
          },
          "background": {
            "activeOnStart": true,
            "beginsPattern": ".*",
            "endsPattern": "INFO:\\s+Application startup complete\\."
          }
        }
      ]
    },
    {
      "label": "dev: manager-ui frontend",
      "type": "process",
      "command": "npm.cmd",
      "args": [
        "--prefix",
        "manager-ui",
        "run",
        "dev"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": [
        {
          "owner": "custom",
          "fileLocation": "absolute",
          "pattern": {
            "regexp": "^(.*)$",
            "file": 1,
            "message": 1
          },
          "background": {
            "activeOnStart": true,
            "beginsPattern": ".*",
            "endsPattern": "Ready in|Local:"
          }
        }
      ]
    },
    {
      "label": "helper: open web dashboard",
      "type": "process",
      "command": "cmd.exe",
      "args": [
        "/d",
        "/c",
        "start",
        "",
        "http://127.0.0.1:3004/dashboard"
      ],
      "problemMatcher": []
    },
    {
      "label": "dev: web tools stack",
      "dependsOrder": "sequence",
      "dependsOn": [
        "bootstrap: dev envs",
        "helper: kill web ports",
        "dev: web manager backend",
        "dev: manager-ui frontend",
        "helper: open web dashboard"
      ],
      "problemMatcher": []
    },
    {
      "label": "dev: webscraper noc dashboard",
      "dependsOrder": "sequence",
      "dependsOn": [
        "dev: web tools stack"
      ],
      "problemMatcher": []
    },
    {
      "label": "stop: web tools stack",
      "type": "process",
      "command": "cmd.exe",
      "args": [
        "/d",
        "/c",
        "call",
        "${workspaceFolder}\\scripts\\kill_ports.bat",
        "8787",
        "3004"
      ],
      "problemMatcher": []
    },
    {
      "label": "stop: webscraper noc dashboard",
      "dependsOrder": "sequence",
      "dependsOn": [
        "stop: web tools stack"
      ],
      "problemMatcher": []
    }
  ]
}