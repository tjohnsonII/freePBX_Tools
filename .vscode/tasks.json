    {
      "label": "open: traceroute ui",
      "type": "process",
      "command": "powershell.exe",
      "args": [
        "-NoProfile",
        "-Command",
        "while(-not (Test-NetConnection 127.0.0.1 -Port 3000).TcpTestSucceeded){Start-Sleep -Milliseconds 300}; Start-Process 'http://127.0.0.1:3000/'"
      ],
      "problemMatcher": []
    },
    {
      "label": "open: webscraper ui",
      "type": "process",
      "command": "powershell.exe",
      "args": [
        "-NoProfile",
        "-Command",
        "while(-not (Test-NetConnection 127.0.0.1 -Port 3004).TcpTestSucceeded){Start-Sleep -Milliseconds 300}; Start-Process 'http://127.0.0.1:3004/dashboard'"
      ],
      "problemMatcher": []
    },
    {
      "label": "kill: dev ports",
      "type": "process",
      "command": "cmd.exe",
      "args": [
        "/d",
        "/c",
        "for %%P in (9230 9231 9232 9233 5678 5679) do @for /f \"tokens=5\" %%a in ('netstat -ano ^| findstr /r /c:\":%%P .*LISTENING\"') do @taskkill /F /PID %%a >nul 2>&1"
      ],
      "problemMatcher": [],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "kill: service ports",
      "type": "process",
      "command": "cmd.exe",
      "args": [
        "/d",
        "/c",
        "for %%P in (3000 3001 3002 3003 3004 3005 3006 3007 3008 3009 3010 8787 8002) do @for /f \"tokens=5\" %%a in ('netstat -ano ^| findstr /r /c:\":%%P .*LISTENING\"') do @taskkill /F /PID %%a >nul 2>&1"
      ],
      "problemMatcher": [],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
