{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "bootstrap: dev envs",
      "type": "process",
      "command": "py",
      "args": [
        "-3",
        "scripts/dev_env_manager.py",
        "bootstrap",
        "--fix-node"
      ],
      "problemMatcher": [],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "doctor: dev envs",
      "type": "process",
      "command": "py",
      "args": [
        "-3",
        "scripts/dev_env_manager.py",
        "doctor"
      ],
      "problemMatcher": [],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "dev: bootstrap envs",
      "type": "shell",
      "dependsOn": [
        "bootstrap: dev envs"
      ],
      "problemMatcher": []
    },
    {
      "label": "helper: ensure manager-ui deps",
      "type": "process",
      "command": "cmd.exe",
      "args": [
        "/d",
        "/c",
        "call",
        "${workspaceFolder}\\scripts\\ensure_node_deps.bat",
        "manager-ui"
      ],
      "problemMatcher": [],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "helper: ensure deploy-ui deps",
      "type": "process",
      "command": "cmd.exe",
      "args": [
        "/d",
        "/c",
        "call",
        "${workspaceFolder}\\scripts\\ensure_node_deps.bat",
        "freepbx-deploy-ui"
      ],
      "problemMatcher": [],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "helper: ensure polycom deps",
      "type": "process",
      "command": "cmd.exe",
      "args": [
        "/d",
        "/c",
        "call",
        "${workspaceFolder}\\scripts\\ensure_node_deps.bat",
        "PolycomYealinkMikrotikSwitchConfig-main\\PolycomYealinkMikrotikSwitchConfig-main"
      ],
      "problemMatcher": [],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "helper: ensure traceroute-ui deps",
      "type": "process",
      "command": "cmd.exe",
      "args": [
        "/d",
        "/c",
        "call",
        "${workspaceFolder}\\scripts\\ensure_node_deps.bat",
        "traceroute-visualizer-main\\traceroute-visualizer-main"
      ],
      "problemMatcher": [],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "helper: kill web tools ports",
      "type": "process",
      "command": "cmd.exe",
      "args": [
        "/d",
        "/c",
        "call",
        "${workspaceFolder}\\scripts\\kill_ports.bat",
        "8787",
        "3004"
      ],
      "problemMatcher": [],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "helper: open web tools ui",
      "type": "process",
      "command": "powershell.exe",
      "args": [
        "-NoProfile",
        "-Command",
        "while(-not (Test-NetConnection 127.0.0.1 -Port 3004).TcpTestSucceeded){Start-Sleep -Milliseconds 300}; Start-Process 'http://127.0.0.1:3004/dashboard'"
      ],
      "problemMatcher": []
    },
    {
      "label": "dev: web tools api",
      "type": "process",
      "command": "cmd.exe",
      "args": [
        "/d",
        "/c",
        "call",
        "${workspaceFolder}\\scripts\\run_py.bat",
        ".venv-web-manager",
        "-m",
        "uvicorn",
        "webscraper_manager.api.server:app",
        "--reload",
        "--host",
        "127.0.0.1",
        "--port",
        "8787"
      ],
      "isBackground": true,
      "problemMatcher": [
        {
          "pattern": [
            {
              "regexp": ".*"
            }
          ],
          "background": {
            "activeOnStart": true,
            "beginsPattern": ".*Uvicorn.*",
            "endsPattern": "(Uvicorn running on|Application startup complete)"
          }
        }
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "dev: web tools ui",
      "type": "process",
      "dependsOn": [
        "helper: ensure manager-ui deps"
      ],
      "dependsOrder": "sequence",
      "command": "npm.cmd",
      "args": [
        "run",
        "dev"
      ],
      "isBackground": true,
      "problemMatcher": [
        {
          "pattern": [
            {
              "regexp": ".*"
            }
          ],
          "background": {
            "activeOnStart": true,
            "beginsPattern": ".*Next\\.js.*",
            "endsPattern": "Ready in"
          }
        }
      ],
      "options": {
        "cwd": "${workspaceFolder}/manager-ui"
      }
    },
    {
      "label": "dev: web tools stack",
      "type": "shell",
      "dependsOn": [
        "helper: kill web tools ports",
        "dev: web tools api",
        "dev: web tools ui",
        "helper: open web tools ui"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "stop: web tools stack",
      "type": "shell",
      "dependsOn": [
        "helper: kill web tools ports"
      ],
      "problemMatcher": []
    },
    {
      "label": "dev: webscraper dashboard backend",
      "type": "shell",
      "dependsOn": [
        "dev: web tools api"
      ],
      "problemMatcher": []
    },
    {
      "label": "dev: manager-ui frontend",
      "type": "shell",
      "dependsOn": [
        "dev: web tools ui"
      ],
      "problemMatcher": []
    },
    {
      "label": "kill: webscraper noc ports",
      "type": "shell",
      "dependsOn": [
        "helper: kill web tools ports"
      ],
      "problemMatcher": []
    },
    {
      "label": "kill: webscraper manager ports",
      "type": "shell",
      "dependsOn": [
        "helper: kill web tools ports"
      ],
      "problemMatcher": []
    },
    {
      "label": "dev: webscraper manager gui startup",
      "type": "shell",
      "dependsOn": [
        "dev: web tools stack"
      ],
      "problemMatcher": []
    },
    {
      "label": "stop: webscraper manager gui",
      "type": "shell",
      "dependsOn": [
        "stop: web tools stack"
      ],
      "problemMatcher": []
    },
    {
      "label": "dev: webscraper noc dashboard",
      "type": "shell",
      "dependsOn": [
        "dev: web tools stack"
      ],
      "problemMatcher": []
    },
    {
      "label": "stop: webscraper noc dashboard",
      "type": "shell",
      "dependsOn": [
        "stop: web tools stack"
      ],
      "problemMatcher": []
    },
    {
      "label": "dev: webscraper stack core (freepbx-tools) [WIN]",
      "type": "process",
      "command": "cmd.exe",
      "args": [
        "/d",
        "/c",
        "call",
        "${workspaceFolder}\\scripts\\kill_ports.bat",
        "&&",
        "call",
        "${workspaceFolder}\\scripts\\run_py.bat",
        ".venv-webscraper",
        "-m",
        "webscraper_manager",
        "start",
        "webscraper"
      ],
      "isBackground": true,
      "problemMatcher": [
        {
          "pattern": [
            {
              "regexp": ".*"
            }
          ],
          "background": {
            "activeOnStart": true,
            "beginsPattern": "Doctor Checks",
            "endsPattern": "webscraper stack ready"
          }
        }
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "WEBSCRAPER_BROWSER": "chrome",
          "WEBSCRAPER_AUTH_MODE": "auto",
          "WEBSCRAPER_AUTH_PAUSE_ON_FAIL": "1",
          "WEBSCRAPER_COOKIES_FILE": "webscraper\\var\\auth\\cookies.json",
          "WEBSCRAPER_PROFILE_NAME": "Default",
          "CHROME_PATH": "C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe",
          "CHROMEDRIVER_PATH": "${env:CHROMEDRIVER_PATH}",
          "WEBSCRAPER_PROFILE_DIR": "webscraper\\var\\chrome-profile"
        }
      }
    },
    {
      "label": "dev: webscraper stack core (freepbx-tools) [WSL]",
      "type": "process",
      "command": "C:\\Windows\\System32\\bash.exe",
      "args": [
        "-lc",
        "if [ -x \".venv-webscraper-wsl/bin/python\" ]; then ./scripts/kill_ports.sh && ./scripts/run_py.sh .venv-webscraper-wsl -m webscraper_manager start webscraper; else echo \"[WSL] No WSL venv found at .venv-webscraper-wsl (skipping)\"; fi"
      ],
      "isBackground": true,
      "problemMatcher": [
        {
          "pattern": [
            {
              "regexp": ".*"
            }
          ],
          "background": {
            "activeOnStart": true,
            "beginsPattern": "Doctor Checks",
            "endsPattern": "webscraper stack ready"
          }
        }
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "WEBSCRAPER_BROWSER": "chrome",
          "WEBSCRAPER_AUTH_MODE": "auto",
          "WEBSCRAPER_AUTH_PAUSE_ON_FAIL": "1",
          "WEBSCRAPER_COOKIES_FILE": "webscraper/var/auth/cookies.json",
          "WEBSCRAPER_PROFILE_NAME": "Default",
          "CHROMEDRIVER_PATH": "${env:CHROMEDRIVER_PATH}",
          "WEBSCRAPER_PROFILE_DIR": "webscraper/var/chrome-profile"
        }
      }
    },
    {
      "label": "dev: webscraper stack (freepbx-tools) [WIN]",
      "type": "shell",
      "dependsOn": [
        "dev: webscraper stack core (freepbx-tools) [WIN]",
        "dev: web tools stack"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "dev: webscraper stack (freepbx-tools) [WSL]",
      "type": "shell",
      "dependsOn": [
        "dev: webscraper stack core (freepbx-tools) [WSL]",
        "dev: web tools stack"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "dev: webscraper stack (freepbx-tools)",
      "type": "shell",
      "dependsOn": [
        "dev: webscraper stack (freepbx-tools) [WIN]"
      ],
      "problemMatcher": []
    },
    {
      "label": "stop: webscraper stack core (freepbx-tools) [WIN]",
      "type": "process",
      "command": "cmd.exe",
      "args": [
        "/d",
        "/c",
        "call",
        "${workspaceFolder}\\scripts\\run_py.bat",
        ".venv-webscraper",
        "-m",
        "webscraper_manager",
        "stop",
        "webscraper",
        "||",
        "call",
        "${workspaceFolder}\\scripts\\kill_ports.bat"
      ],
      "problemMatcher": [],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "stop: webscraper stack core (freepbx-tools) [WSL]",
      "type": "process",
      "command": "C:\\Windows\\System32\\bash.exe",
      "args": [
        "-lc",
        "if [ -x \".venv-webscraper-wsl/bin/python\" ]; then ./scripts/run_py.sh .venv-webscraper-wsl -m webscraper_manager stop webscraper || ./scripts/kill_ports.sh; else echo \"[WSL] No WSL venv found at .venv-webscraper-wsl (skipping)\"; fi"
      ],
      "problemMatcher": [],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "stop: webscraper stack (freepbx-tools) [WIN]",
      "type": "shell",
      "dependsOn": [
        "stop: webscraper stack core (freepbx-tools) [WIN]",
        "stop: web tools stack"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "stop: webscraper stack (freepbx-tools) [WSL]",
      "type": "shell",
      "dependsOn": [
        "stop: webscraper stack core (freepbx-tools) [WSL]",
        "stop: web tools stack"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "stop: webscraper stack (freepbx-tools)",
      "type": "shell",
      "dependsOn": [
        "stop: webscraper stack (freepbx-tools) [WIN]"
      ],
      "problemMatcher": []
    },
    {
      "label": "dev: deploy-backend",
      "type": "process",
      "command": "cmd.exe",
      "args": [
        "/d",
        "/c",
        "call",
        "${workspaceFolder}\\scripts\\run_py.bat",
        "freepbx-deploy-backend\\.venv",
        "-m",
        "uvicorn",
        "freepbx_deploy_backend.main:app",
        "--reload",
        "--host",
        "127.0.0.1",
        "--port",
        "8002"
      ],
      "isBackground": true,
      "problemMatcher": [
        {
          "pattern": [
            {
              "regexp": ".*"
            }
          ],
          "background": {
            "activeOnStart": true,
            "beginsPattern": ".*Uvicorn.*",
            "endsPattern": "(Uvicorn running on|Application startup complete)"
          }
        }
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "dev: deploy-ui",
      "type": "process",
      "dependsOn": [
        "helper: ensure deploy-ui deps"
      ],
      "dependsOrder": "sequence",
      "command": "npm.cmd",
      "args": [
        "run",
        "dev"
      ],
      "isBackground": true,
      "problemMatcher": [
        {
          "pattern": [
            {
              "regexp": ".*"
            }
          ],
          "background": {
            "activeOnStart": true,
            "beginsPattern": "VITE v",
            "endsPattern": "Local:\\s+http://"
          }
        }
      ],
      "options": {
        "cwd": "${workspaceFolder}/freepbx-deploy-ui"
      }
    },
    {
      "label": "dev: polycom app",
      "type": "process",
      "dependsOn": [
        "helper: ensure polycom deps"
      ],
      "dependsOrder": "sequence",
      "command": "npm.cmd",
      "args": [
        "run",
        "dev"
      ],
      "isBackground": true,
      "problemMatcher": [
        {
          "pattern": [
            {
              "regexp": ".*"
            }
          ],
          "background": {
            "activeOnStart": true,
            "beginsPattern": "VITE v",
            "endsPattern": "Local:\\s+http://"
          }
        }
      ],
      "options": {
        "cwd": "${workspaceFolder}/PolycomYealinkMikrotikSwitchConfig-main/PolycomYealinkMikrotikSwitchConfig-main"
      }
    },
    {
      "label": "dev: traceroute ui",
      "type": "process",
      "dependsOn": [
        "helper: ensure traceroute-ui deps"
      ],
      "dependsOrder": "sequence",
      "command": "npm.cmd",
      "args": [
        "run",
        "dev",
        "--",
        "-p",
        "3000"
      ],
      "isBackground": true,
      "problemMatcher": [
        {
          "pattern": [
            {
              "regexp": ".*"
            }
          ],
          "background": {
            "activeOnStart": true,
            "beginsPattern": ".*Next\\.js.*",
            "endsPattern": "Ready in"
          }
        }
      ],
      "options": {
        "cwd": "${workspaceFolder}/traceroute-visualizer-main/traceroute-visualizer-main"
      }
    },
    {
      "label": "dev: traceroute backend",
      "type": "process",
      "command": "cmd.exe",
      "args": [
        "/d",
        "/c",
        "call",
        "${workspaceFolder}\\scripts\\run_py.bat",
        "traceroute-visualizer-main\\backend\\.venv",
        "-m",
        "uvicorn",
        "traceroute_server:app",
        "--reload",
        "--host",
        "127.0.0.1",
        "--port",
        "8001"
      ],
      "isBackground": true,
      "problemMatcher": [
        {
          "pattern": [
            {
              "regexp": ".*"
            }
          ],
          "background": {
            "activeOnStart": true,
            "beginsPattern": ".*Uvicorn.*",
            "endsPattern": "(Uvicorn running on|Application startup complete)"
          }
        }
      ],
      "options": {
        "cwd": "${workspaceFolder}/traceroute-visualizer-main/backend"
      }
    },
    {
      "label": "open: traceroute ui",
      "type": "process",
      "command": "powershell.exe",
      "args": [
        "-NoProfile",
        "-Command",
        "while(-not (Test-NetConnection 127.0.0.1 -Port 3000).TcpTestSucceeded){Start-Sleep -Milliseconds 300}; Start-Process 'http://127.0.0.1:3000/'"
      ],
      "problemMatcher": []
    },
    {
      "label": "dev: cli manager",
      "type": "process",
      "command": "cmd.exe",
      "args": [
        "/d",
        "/c",
        "py",
        "-3",
        "freepbx_tools_manager.py"
      ],
      "problemMatcher": [],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "dev: all apps + cli",
      "type": "shell",
      "dependsOn": [
        "dev: traceroute ui",
        "dev: deploy-ui",
        "dev: polycom app",
        "dev: deploy-backend",
        "dev: webscraper stack (freepbx-tools)",
        "dev: cli manager",
        "open: traceroute ui"
      ],
      "dependsOrder": "parallel",
      "problemMatcher": []
    },
    {
      "label": "Start Everything + CLI",
      "type": "shell",
      "dependsOn": [
        "dev: all apps + cli"
      ],
      "problemMatcher": []
    }
  ]
}
