    {
      "label": "dev: traceroute (inspect 9230)",
      "type": "process",
      "command": "npm.cmd",
      "args": [
        "run",
        "dev",
        "--",
        "-p",
        "3000"
      ],
      "isBackground": true,
      "problemMatcher": [
        {
          "pattern": [
            {
              "regexp": ".*"
            }
          ],
          "background": {
            "activeOnStart": true,
            "beginsPattern": "\u25b2 Next\\.js",
            "endsPattern": "Ready in"
          }
        }
      ],
      "options": {
        "cwd": "${workspaceFolder}/traceroute-visualizer-main/traceroute-visualizer-main",
        "env": {
          "NODE_OPTIONS": "--inspect=9230"
        }
      }
    },
