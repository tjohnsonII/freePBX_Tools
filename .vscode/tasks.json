{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "start: apps",
      "type": "process",
      "command": "python",
      "args": [
        "${workspaceFolder}\\scripts\\run_all_web_apps.py",
        "--browser",
        "existing-profile",
        "--webscraper-mode",
        "combined",
        "--doctor",
        "--strict-readiness"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": true,
        "echo": true,
        "clear": false
      },
      "problemMatcher": []
    },
    {
      "label": "start: apps (no browser)",
      "type": "process",
      "command": "python",
      "args": [
        "${workspaceFolder}\\scripts\\run_all_web_apps.py",
        "--browser",
        "none",
        "--webscraper-mode",
        "combined",
        "--doctor",
        "--strict-readiness"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": true,
        "echo": true,
        "clear": false
      },
      "problemMatcher": []
    },
    {
      "label": "start: inspect",
      "type": "process",
      "command": "python",
      "args": [
        "${workspaceFolder}\\scripts\\run_all_web_apps.py",
        "--inspect",
        "--browser",
        "none",
        "--webscraper-mode",
        "combined"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": false,
        "echo": true,
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "doctor: apps",
      "type": "process",
      "command": "python",
      "args": [
        "${workspaceFolder}\\scripts\\run_all_web_apps.py",
        "--doctor",
        "--dry-run",
        "--browser",
        "none",
        "--webscraper-mode",
        "combined"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": false,
        "echo": true,
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "stop: apps",
      "type": "process",
      "command": "python",
      "args": [
        "${workspaceFolder}\\scripts\\stop_all_web_apps.py"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": false,
        "echo": true,
        "clear": false
      },
      "problemMatcher": []
    }
  ]
}
