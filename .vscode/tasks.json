    {
      "label": "dev: webscraper stack core (freepbx-tools) [WIN]",
      "type": "process",
      "command": "cmd.exe",
      "args": [
        "/d",
        "/c",
        "call",
        "${workspaceFolder}\\scripts\\kill_ports.bat",
        "&&",
        "call",
        "${workspaceFolder}\\scripts\\run_py.bat",
        ".venv-webscraper",
        "-m",
        "webscraper_manager",
        "start",
        "webscraper"
      ],
      "isBackground": true,
      "problemMatcher": [
        {
          "pattern": [
            {
              "regexp": ".*"
            }
          ],
          "background": {
            "activeOnStart": true,
            "beginsPattern": "Doctor Checks",
            "endsPattern": "webscraper stack ready"
          }
        }
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "WEBSCRAPER_BROWSER": "chrome",
          "WEBSCRAPER_AUTH_MODE": "auto",
          "WEBSCRAPER_AUTH_PAUSE_ON_FAIL": "1",
          "WEBSCRAPER_COOKIES_FILE": "webscraper\\var\\auth\\cookies.json",
          "WEBSCRAPER_PROFILE_NAME": "Default",
          "CHROME_PATH": "C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe",
          "CHROMEDRIVER_PATH": "${env:CHROMEDRIVER_PATH}",
          "WEBSCRAPER_PROFILE_DIR": "webscraper\\var\\chrome-profile"
        }
      }
    },
    {
      "label": "dev: webscraper stack core (freepbx-tools) [WSL]",
      "type": "process",
      "command": "C:\\Windows\\System32\\bash.exe",
      "args": [
        "-lc",
        "if [ -x \".venv-webscraper-wsl/bin/python\" ]; then ./scripts/kill_ports.sh && ./scripts/run_py.sh .venv-webscraper-wsl -m webscraper_manager start webscraper; else echo \"[WSL] No WSL venv found at .venv-webscraper-wsl (skipping)\"; fi"
      ],
      "isBackground": true,
      "problemMatcher": [
        {
          "pattern": [
            {
              "regexp": ".*"
            }
          ],
          "background": {
            "activeOnStart": true,
            "beginsPattern": "Doctor Checks",
            "endsPattern": "webscraper stack ready"
