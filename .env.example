# Client-mode configuration — copy this to .env and fill in your values
# .env is gitignored and never committed

CLIENT_MODE=1

# URL of the server running the ticket API (Apache proxy, HTTPS preferred)
INGEST_SERVER_URL=https://ticket-api.123hostedtools.com

# Shared secret — must match INGEST_API_KEY on the server (.env in server repo)
INGEST_API_KEY=your-key-here

# Local port this client's trigger API listens on (optional, default 8789)
WEBSCRAPER_PORT=8789

# Path to chromedriver binary (optional — auto-detected from bundled copy or PATH)
# On Windows the bundled chromedriver.exe in webscraper/chromedriver-win64/ is used automatically.
# Override only if you want a specific version:
# WEBSCRAPER_CHROMEDRIVER_PATH=C:/path/to/chromedriver.exe

# Seconds to wait for you to complete login in the Selenium Chrome window (default 300).
# Increase if SSO/MFA takes longer. The Chrome window opens on the VNC display —
# connect via VNC and log in ONLY in that window, not in any other browser.
SELENIUM_FALLBACK_LOGIN_TIMEOUT_SECONDS=600
